NODE_ENV=development
PORT=4000
DATABASE_DRIVER=supabase

# Used by API runtime when DATABASE_DRIVER=supabase.
SUPABASE_URL=https://tpwcbgfapgpgwodwxjdv.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_VC-LZPB0WzHbVJaMmCrwiw_pGBPiFyG
NEXT_PUBLIC_SUPABASE_URL=https://tpwcbgfapgpgwodwxjdv.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_VC-LZPB0WzHbVJaMmCrwiw_pGBPiFyG

# Used by npm run db:migrate and npm run db:seed.
# Replace <YOUR_DATABASE_PASSWORD> with the database password from Supabase.
DATABASE_URL=postgresql://postgres:<YOUR_DATABASE_PASSWORD>@db.tpwcbgfapgpgwodwxjdv.supabase.co:5432/postgres
DATABASE_SSL=true

CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# Phase 3 auth.
# Use long random values in real environments.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=2592000
GOOGLE_OAUTH_CLIENT_ID=

# Phase 2 recommendation and Gemini fallback.
# Leave GEMINI_API_KEY empty to disable AI fallback locally.
RECOMMENDATION_MATCH_THRESHOLD=0.55
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
